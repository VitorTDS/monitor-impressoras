# Servidor
PORT=3000

# Banco de dados
# Docker: /data/banco.db  |  Dev local: ./banco.db
DATABASE_PATH=/data/banco.db

# Autenticação
ADMIN_USER=admin
ADMIN_SENHA=troque-esta-senha
ESTOQUE_SENHA=troque-este-token

# CORS — domínio de onde o frontend será servido
# Deixe em branco para desativar restrição (não recomendado em produção)
ALLOWED_ORIGIN=https://seudominio.com
